{
  "_comment": "Cross-SDK config-validation parity fixture. Python's load_config_from_dict and JS's loadConfigFromDict MUST agree on accept/reject for every case here — this is the guard against the Python<->JS validation drift found in the config schema review (missing version check, unvalidated signup_grant/allowance sign, unknown-key typos, dropped per_operation, etc). Both runners load this file directly; do not hand-duplicate cases in engine-specific test files.",
  "cases": [
    {
      "name": "minimal_valid_config",
      "expect": "accept",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } } }
    },
    {
      "name": "missing_models",
      "expect": "reject",
      "reason": "metering is required",
      "config": {}
    },
    {
      "name": "empty_models",
      "expect": "reject",
      "reason": "metering.models must be a non-empty dict",
      "config": { "metering": { "models": {} } }
    },
    {
      "name": "version_1_accepted",
      "expect": "accept",
      "config": { "version": 1, "metering": { "models": { "*": "input_tokens * 1" } } }
    },
    {
      "name": "version_2_rejected",
      "expect": "reject",
      "reason": "only version 1 is valid",
      "config": { "version": 2, "metering": { "models": { "*": "input_tokens * 1" } } }
    },
    {
      "name": "version_string_rejected",
      "expect": "reject",
      "reason": "version must be an int, not a string",
      "config": { "version": "1", "metering": { "models": { "*": "input_tokens * 1" } } }
    },
    {
      "name": "unknown_top_level_key_rejected",
      "expect": "reject",
      "reason": "typo'd key must not silently fall back to a default",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "min_balnce": 5 }
    },
    {
      "name": "negative_min_balance_rejected",
      "expect": "reject",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "min_balance": -1 } }
    },
    {
      "name": "min_balance_string_coerced",
      "expect": "accept",
      "reason": "numeric strings coerce to the money type, not rejected",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "min_balance": "10" } }
    },
    {
      "name": "negative_signup_bonus_rejected",
      "expect": "reject",
      "reason": "scalar signup_grant is no longer accepted",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "signup_grant": -1 } }
    },
    {
      "name": "zero_signup_bonus_scalar_rejected",
      "expect": "reject",
      "reason": "scalar signup_grant is no longer accepted; omit the key for no bonus",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "signup_grant": 0 } }
    },
    {
      "name": "signup_grant_object_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "signup_grant": { "amount": 50, "bucket": "gifted" },
          "buckets": {
            "gifted": { "label": "Gifted", "priority": 10 },
            "purchased": { "label": "Purchased", "priority": 30, "default": true }
          }
        }
      }
    },
    {
      "name": "signup_grant_scalar_rejected",
      "expect": "reject",
      "reason": "signup_grant must be an object { amount, bucket }",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "signup_grant": 50 } }
    },
    {
      "name": "signup_grant_unknown_bucket_rejected",
      "expect": "reject",
      "reason": "signup_grant.bucket must reference a configured ledger.buckets key",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "signup_grant": { "amount": 50, "bucket": "missing" },
          "buckets": { "gifted": { "label": "Gifted", "priority": 10 } }
        }
      }
    },
    {
      "name": "signup_grant_without_buckets_rejected",
      "expect": "reject",
      "reason": "ledger.buckets must be defined when signup_grant is set",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": { "signup_grant": { "amount": 50, "bucket": "gifted" } }
      }
    },
    {
      "name": "negative_fixed_cost_rejected",
      "expect": "reject",
      "config": { "metering": { "models": { "*": "input_tokens * 1" }, "flat_jobs": { "batch_job": -1 } } }
    },
    {
      "name": "fractional_fixed_cost_accepted",
      "expect": "accept",
      "config": { "metering": { "models": { "*": "input_tokens * 1" }, "flat_jobs": { "batch_job": 2.5 } } }
    },
    {
      "name": "empty_tiers_dict_rejected",
      "expect": "reject",
      "reason": "ambiguous — omit the buckets key entirely for no buckets",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } }, "ledger": { "buckets": {} } }
    },
    {
      "name": "two_default_overdraft_tiers_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "buckets": {
            "a": { "label": "A", "priority": 1, "allow_overdraft": true },
            "b": { "label": "B", "priority": 2, "allow_overdraft": true }
          }
        }
      }
    },
    {
      "name": "two_is_default_tiers_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "buckets": {
            "a": { "label": "A", "priority": 1, "default": true },
            "b": { "label": "B", "priority": 2, "default": true }
          }
        }
      }
    },
    {
      "name": "non_positive_default_ttl_days_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "buckets": { "a": { "label": "A", "priority": 1, "expires": true, "ttl_days": 0 } }
        }
      }
    },
    {
      "name": "valid_tiers_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "buckets": {
            "gifted": { "label": "Gifted", "priority": 10, "expires": true, "ttl_days": 30 },
            "purchased": { "label": "Purchased", "priority": 30, "default": true, "allow_overdraft": true }
          }
        }
      }
    },
    {
      "name": "unknown_key_in_tier_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "ledger": {
          "buckets": { "a": { "label": "A", "priority": 1, "expres": true } }
        }
      }
    },
    {
      "name": "plan_missing_name_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": {} }
      }
    },
    {
      "name": "duplicate_plan_names_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": {
          "a": { "label": "Pro" },
          "b": { "label": "Pro" }
        }
      }
    },
    {
      "name": "plan_negative_free_allowance_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "cheap": { "label": "Cheap", "allowance": { "amount": -10, "period": "calendar_month" } } }
      }
    },
    {
      "name": "plan_rate_overrides_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "gpt-4": "input_tokens * 1", "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro", "rate_overrides": { "gpt-4": "input_tokens * 0.003" } } }
      }
    },
    {
      "name": "unknown_key_in_plan_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro", "free_allownce": 5 } }
      }
    },
    {
      "name": "plan_per_operation_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": {
          "pro": {
            "label": "Pro",
            "safety": { "per_operation": { "agent": { "billing_mode": "overdraft", "overdraft_floor": -30 } } }
          }
        }
      }
    },
    {
      "name": "plan_per_operation_invalid_billing_mode_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": {
          "pro": { "label": "Pro", "safety": { "per_operation": { "agent": { "billing_mode": "bogus" } } } }
        }
      }
    },
    {
      "name": "unknown_variable_typo_rejected",
      "expect": "reject",
      "config": { "metering": { "models": { "*": "inputtokens * 0.001" } } }
    },
    {
      "name": "this_tool_calls_in_models_rejected",
      "expect": "reject",
      "reason": "calls is scoped to tools expressions only",
      "config": { "metering": { "models": { "*": "calls * 1" } } }
    },
    {
      "name": "this_tool_calls_in_tools_accepted",
      "expect": "accept",
      "config": {
        "metering": {
          "models": { "*": "input_tokens * 1" },
          "tools": { "code_exec": "calls * 10 / 1000" }
        }
      }
    },
    {
      "name": "exponentiation_rejected",
      "expect": "reject",
      "config": { "metering": { "models": { "*": "input_tokens ** 2" } } }
    },
    {
      "name": "no_variables_in_expression_rejected",
      "expect": "reject",
      "reason": "an expression with no metric-variable reference is rejected at config-load time",
      "config": { "metering": { "models": { "*": "1" } } }
    },
    {
      "name": "tools_omitted_defaults",
      "expect": "accept",
      "config": { "metering": { "models": { "*": "input_tokens * 1" } } }
    },
    {
      "name": "plan_rate_overrides_unknown_model_rejected",
      "expect": "reject",
      "reason": "rate_overrides keys must reference metering.models or '*'",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": {
          "pro": { "label": "Pro", "rate_overrides": { "unknown-model": "input_tokens * 0.003" } }
        }
      }
    },
    {
      "name": "plan_rate_overrides_wildcard_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro", "rate_overrides": { "*": "input_tokens * 0.003" } } }
      }
    },
    {
      "name": "entitlement_missing_max_calls_unlimited",
      "expect": "accept",
      "reason": "missing max_calls means unlimited (no invocation cap)",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro", "entitlements": { "ai_chat": { "value": true } } } }
      }
    },
    {
      "name": "entitlement_negative_max_calls_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": {
          "pro": { "label": "Pro", "entitlements": { "export": { "max_calls": -1 } } }
        }
      }
    },
    {
      "name": "billing_section_valid_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": {
            "pro-monthly": {
              "plan": "pro",
              "interval": "month",
              "grant": { "mode": "allowance" },
              "providers": { "stripe": { "price_id": "price_pro" } }
            }
          },
          "topups": {
            "credits": {
              "deposit_to": "purchased",
              "credits_per_unit": 1000,
              "providers": { "stripe": { "price_id": "price_topup" } }
            }
          }
        }
      }
    },
    {
      "name": "billing_offer_valid_from_to_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "ledger": {
          "buckets": {
            "gifted": { "label": "Gifted", "priority": 10 }
          }
        },
        "billing": {
          "subscriptions": {
            "pro-monthly": {
              "plan": "pro",
              "valid_from": "2025-01-01",
              "valid_to": "2025-12-31",
              "grant": { "mode": "allowance" }
            }
          }
        }
      }
    },
    {
      "name": "billing_offer_unknown_key_rejected",
      "expect": "reject",
      "reason": "typo'd key must not be silently ignored",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": {
            "pro-monthly": {
              "plan": "pro",
              "valid_till": "2025-12-31",
              "grant": { "mode": "allowance" }
            }
          }
        }
      }
    },
    {
      "name": "subscription_plan_dangling_no_plans_rejected",
      "expect": "reject",
      "reason": "billing.subscriptions plan must reference an existing plans key",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "billing": {
          "subscriptions": { "pro-monthly": { "plan": "pro", "grant": { "mode": "allowance" } } }
        }
      }
    },
    {
      "name": "subscription_plan_dangling_unknown_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": { "pro-monthly": { "plan": "nope", "grant": { "mode": "allowance" } } }
        }
      }
    },
    {
      "name": "grant_cycle_missing_credits_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": { "annual": { "plan": "pro", "grant": { "mode": "cycle_grant" } } }
        }
      }
    },
    {
      "name": "grant_allowance_extra_fields_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": {
            "monthly": { "plan": "pro", "grant": { "mode": "allowance", "credits": 500 } }
          }
        }
      }
    },
    {
      "name": "grant_cycle_missing_bucket_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "plans": { "pro": { "label": "Pro" } },
        "billing": {
          "subscriptions": { "annual": { "plan": "pro", "grant": { "mode": "cycle_grant", "credits": 500 } } }
        }
      }
    },
    {
      "name": "topup_missing_deposit_to_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "billing": { "topups": { "x": { "credits_per_unit": 1000 } } }
      }
    },
    {
      "name": "topups_deposit_to_accepted",
      "expect": "accept",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "billing": { "topups": { "x": { "deposit_to": "purchased" } } }
      }
    },
    {
      "name": "topups_old_tier_rejected",
      "expect": "reject",
      "config": {
        "metering": { "models": { "*": "input_tokens * 1" } },
        "billing": { "topups": { "x": { "tier": "purchased" } } }
      }
    },
    {
      "name": "camel_case_config_field_rejected",
      "expect": "reject",
      "config": {
        "metering": {
          "models": { "*": "input_tokens * 1" },
          "cacheDiscount": "input_tokens * 0"
        }
      }
    },
    {
      "name": "mixed_case_duplicate_rejected",
      "expect": "reject",
      "config": {
        "metering": {
          "models": { "*": "input_tokens * 1" },
          "cache_discount": "input_tokens * 0",
          "cacheDiscount": "input_tokens * 0"
        }
      }
    }
  ]
}
